<Window x:Class="CodexPalette.Native.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Codex Palette" Width="212" Height="50" WindowStyle="None"
 AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize"
 ShowInTaskbar="False" ShowActivated="False" Topmost="True" Opacity="0"
 Loaded="Window_Loaded" Closed="Window_Closed" KeyDown="Window_KeyDown">
 <Grid>
  <Border Background="Transparent" BorderBrush="#33000000" BorderThickness="1" CornerRadius="12">
   <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/>
    <Style.Triggers><DataTrigger Binding="{Binding IsOpen}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
   </Style></Border.Style>
   <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition/></Grid.ColumnDefinitions>
    <Border Background="#B02D2C29" CornerRadius="11,0,0,11" Cursor="SizeAll" MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
     <TextBlock Text="⋮" FontSize="19" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
    <Button Grid.Column="1" Background="{Binding SelectedAccentBrush}" BorderThickness="0" Cursor="Hand" Click="Toggle_Click">
     <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="0,11,11,0"><ContentPresenter/></Border></ControlTemplate></Button.Template>
     <Grid Margin="11,0,8,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel VerticalAlignment="Center"><TextBlock Text="{Binding SelectedModelName}" FontWeight="SemiBold" FontSize="12.5" Foreground="White" TextTrimming="CharacterEllipsis"/>
       <TextBlock Text="{Binding SelectedEffortName}" FontSize="10.5" Foreground="#EFFFFFFF" TextTrimming="CharacterEllipsis"/></StackPanel>
      <TextBlock Grid.Column="1" Text="⌄" FontSize="17" Foreground="White" VerticalAlignment="Center"/>
     </Grid>
    </Button>
   </Grid>
  </Border>
  <Border Background="#F9F8F4" BorderBrush="#26000000" BorderThickness="1" CornerRadius="16" Padding="10">
   <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/>
    <Style.Triggers><DataTrigger Binding="{Binding IsOpen}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
   </Style></Border.Style>
   <Grid><Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition/><RowDefinition Height="43"/></Grid.RowDefinitions>
    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="31"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
     <Border Width="31" Height="28" Background="#0B000000" CornerRadius="8" Cursor="SizeAll" MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
      <TextBlock Text="⋮" FontSize="19" Foreground="#77766F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
     </Border>
     <TextBlock Grid.Column="1" Text="Codex Palette" FontSize="12" FontWeight="SemiBold" Foreground="#44423D" VerticalAlignment="Center" Margin="10,0"/>
     <StackPanel Grid.Column="2" Orientation="Horizontal">
      <Button Content="⛓" ToolTip="{Binding ThreadLinkStatus}" Click="LinkThread_Click">
       <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Style.Triggers><DataTrigger Binding="{Binding IsThreadLinked}" Value="True"><Setter Property="Background" Value="#2244A06D"/><Setter Property="Foreground" Value="#2F7D59"/></DataTrigger></Style.Triggers>
       </Style></Button.Style>
      </Button>
      <Button Style="{StaticResource IconButton}" Content="↻" ToolTip="Reset position" Click="ResetPosition_Click"/>
      <Button Style="{StaticResource IconButton}" Content="−" ToolTip="Collapse" Click="Collapse_Click"/>
      <Button Style="{StaticResource IconButton}" Content="×" ToolTip="Quit" Click="Quit_Click"/>
     </StackPanel>
    </Grid>
    <StackPanel Grid.Row="1">
     <Grid Margin="0,1,0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="98"/><ColumnDefinition/></Grid.ColumnDefinitions>
      <ItemsControl Grid.Column="1" ItemsSource="{Binding Models}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="{Binding DataContext.ModelColumnCount, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
       <ItemsControl.ItemTemplate><DataTemplate><StackPanel HorizontalAlignment="Center" Margin="3,0"><TextBlock Text="{Binding Glyph}" Foreground="{Binding AccentBrush}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="{Binding Name}" Foreground="#4C4B45" FontSize="10.5" FontWeight="SemiBold" HorizontalAlignment="Center"/></StackPanel></DataTemplate></ItemsControl.ItemTemplate>
      </ItemsControl>
     </Grid>
     <ItemsControl ItemsSource="{Binding EffortRows}"><ItemsControl.ItemTemplate><DataTemplate><Grid Height="43"><Grid.ColumnDefinitions><ColumnDefinition Width="98"/><ColumnDefinition/></Grid.ColumnDefinitions>
      <TextBlock Text="{Binding Label}" Foreground="#626159" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
      <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="{Binding DataContext.ModelColumnCount, RelativeSource={RelativeSource AncestorType=Window}}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
       <ItemsControl.ItemTemplate><DataTemplate><Button Style="{StaticResource CellButton}" IsEnabled="{Binding IsSupported}" Click="PaletteCell_Click" ToolTip="{Binding ModelName}"/></DataTemplate></ItemsControl.ItemTemplate>
      </ItemsControl></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
    </StackPanel>
    <Grid Grid.Row="2" Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
     <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding HasSpeeds, Converter={StaticResource BooleanToVisibilityConverter}}">
      <TextBlock Text="◷" FontSize="14" Foreground="#696860" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="{Binding SpeedLabel}" FontSize="11" Foreground="#696860" VerticalAlignment="Center" Margin="0,0,8,0"/>
      <Border Background="#0A000000" CornerRadius="9" Padding="2"><ItemsControl ItemsSource="{Binding Speeds}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
       <ItemsControl.ItemTemplate><DataTemplate><Button Style="{StaticResource SpeedButton}" Content="{Binding Label}" Click="SpeedOption_Click"/></DataTemplate></ItemsControl.ItemTemplate>
      </ItemsControl></Border>
     </StackPanel>
     <TextBlock Grid.Column="1" Text="{Binding ThreadLinkStatus}" Foreground="#2F7D59" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="190" Visibility="{Binding IsThreadLinked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
     <TextBlock Grid.Column="2" Text="{Binding Notice}" Foreground="#77766E" FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="250" Visibility="{Binding HasNotice, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
   </Grid>
  </Border>
 </Grid>
</Window>
